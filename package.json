{
  "name": "bookjumpr",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BookJumpr — the network of books mentioned inside other books. Static site + SQLite data pipeline.",
  "scripts": {
    "bj": "node --experimental-sqlite --no-warnings tools/bookjumpr.mjs",
    "bj:seed": "node --experimental-sqlite --no-warnings tools/bookjumpr.mjs seed --verify",
    "bj:build": "node --experimental-sqlite --no-warnings tools/bookjumpr.mjs build",
    "bj:doctor": "node --experimental-sqlite --no-warnings tools/bookjumpr.mjs doctor",
    "bj:export": "node --experimental-sqlite --no-warnings tools/bookjumpr.mjs export-csv",
    "serve": "python3 -m http.server 8917",
    "admin": "node --experimental-sqlite --no-warnings tools/admin-server.mjs"
  },
  "engines": {
    "node": ">=22.5"
  }
}
